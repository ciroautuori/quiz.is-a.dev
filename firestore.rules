rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Leaderboard
    match /leaderboard/{recordId} {
      allow read: if true;
      allow create: if isValidId(recordId) 
        && request.resource.data.keys().hasAll(['id', 'nomeUtente', 'punteggio', 'data'])
        && request.resource.data.nomeUtente is string
        && request.resource.data.nomeUtente.size() <= 50
        && request.resource.data.punteggio is number;
      allow update, delete: if false;
    }

    // Custom Questions
    match /custom_questions/{questionId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isValidId(questionId)
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.domanda is string
        && request.resource.data.domanda.size() <= 1000
        && request.resource.data.opzioni is list
        && request.resource.data.opzioni.size() == 4;
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // User progress
    match /users/{userId}/progress/main {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == userId;
      allow delete: if isOwner(userId);
    }
  }
}
